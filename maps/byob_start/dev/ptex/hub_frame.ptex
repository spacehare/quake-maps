								"instance": "vec3 $(name)_distance_h(vec2 uv, bool tile) {\n\tvec2 e = vec2(1.0/$s, 0.0);\n\tint steps = int($s*$d($uv));\n\tfloat rv = 0.0;\n\tvec2 source_uv;\n\tfor (int i = 0; i < steps; ++i) {\n\t\tsource_uv = uv+float(i)*e;\n\t\tif ((tile || (source_uv.x >= 0.0 && source_uv.x <= 1.0)) && $in(source_uv) > 0.5) {\n\t\t\trv = 1.0-float(i)*e.x/$d($uv);\n\t\t\tbreak;\n\t\t}\n\t\tsource_uv = uv-float(i)*e;\n\t\tif ((tile || (source_uv.x >= 0.0 && source_uv.x <= 1.0)) && $in(source_uv) > 0.5) {\n\t\t\trv = 1.0-float(i)*e.x/$d($uv);\n\t\t\tbreak;\n\t\t}\n\t}\n\treturn vec3(rv, source_uv);\n}\n",
								"name": "Dilate pass 1",
								"outputs": [
