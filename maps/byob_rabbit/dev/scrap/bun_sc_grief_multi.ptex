										"label": "",
										"name": "d",
										"type": "f"
									}
								],
								"instance": "vec3 $(name)_distance_v(vec2 uv, bool tile) {\n\tvec2 e = vec2(0.0, 1.0/$s);\n\tint steps = int($s*$d($uv));\n\tvec3 p = vec3($in(uv).xy, uv.y);\n\tvec2 source_uv;\n\tfor (int i = 0; i < steps; ++i) {\n\t\tvec2 dx = float(i)*e;\n\t\tsource_uv = uv+dx;\n\t\tif (tile || (source_uv.y >= 0.0 && source_uv.y < 1.0)) {\n\t\t\tvec3 p2 = vec3($in(source_uv).xy, source_uv.y);\n\t\t\tif (p2.x > p.x) {\n\t\t\t\tp2.x = dilate_distance_$distance(p2.x, dx.y, $d($uv));\n\t\t\t\tp = mix(p, p2, step(p.x, p2.x));\n\t\t\t}\n\t\t}\n\t\tsource_uv = uv-dx;\n\t\tif (tile || (source_uv.y >= 0.0 && source_uv.y < 1.0)) {\n\t\t\tvec3 p2 = vec3($in(source_uv).xy, source_uv.y);\n\t\t\tif (p2.x > p.x) {\n\t\t\t\tp2.x = dilate_distance_$distance(p2.x, dx.y, $d($uv));\n\t\t\t\tp = mix(p, p2, step(p.x, p2.x));\n\t\t\t}\n\t\t}\n\t}\n\treturn p;\n}\n",
