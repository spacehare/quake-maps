								"s": 8.0
							},
							"seed_int": 0,
							"shader_model": {
								"code": "",
								"global": "float kernel(float x){\n\tfloat EPS = 5.79334e-21;\n\tfloat PI = 3.1415927;\n\treturn sin( PI*x + EPS) / ( PI*x + EPS);\n}",
								"inputs": [
									{
										"default": "vec4(0.0)",
										"function": true,
										"label": "",
										"name": "in",
										"type": "rgba"
									}
								],
								"instance": "vec4 $(name)_M(vec2 uv, vec2 D) {\n\tfloat MID_WEIGHT = 1.0;\n\tfloat KERNEL = 2.0;\n\tfloat RANGE = floor(KERNEL * 32.0);\n\t\n\tfloat l = length(D);                           \n    vec4  s =  $in(uv) * MID_WEIGHT * kernel(0.0);       \n\tfloat o = 1.0/$s;\n   for(float d = 1.0; d < RANGE - 0.5; d++ )\n\t{          \n\t\ts += (  $in(uv + d*D*o ) + $in(uv - d*D*o ) ) * kernel( l * d / KERNEL);\n\t}\n                                 \n\treturn s / s.a;\n}",
								"name": "filter",
								"outputs": [
