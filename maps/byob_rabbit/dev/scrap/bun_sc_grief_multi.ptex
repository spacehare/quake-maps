							},
							{
								"control": "None",
								"default": 0.2,
								"label": "Height Multiplier",
								"longdesc": "The height multiplier is used to determine the length of shadows. Think of it as how tall a completely white value is a height map is in comparison to the whole texture being 1 by 1 unit in size.",
								"max": 1.0,
