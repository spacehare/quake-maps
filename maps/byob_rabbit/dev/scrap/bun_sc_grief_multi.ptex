								"label": "",
								"name": "in",
								"type": "rgba"
							}
						],
						"instance": "//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n//  Copyright (c) 2018-2019 Michele Morrone\n//  All rights reserved.\n//\n//  https://michelemorrone.eu - https://BrutPitt.com\n//\n//  me@michelemorrone.eu - brutpitt@gmail.com\n//  twitter: @BrutPitt - github: BrutPitt\n//  \n//  https://github.com/BrutPitt/glslSmartDeNoise/\n//\n//  This software is distributed under the terms of the BSD 2-Clause license\n//  Adapted for Material Maker by wojtekpil\n//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n//  smartDeNoise - parameters\n//~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n//\n//  sampler2D tex\t - sampler image / texture\n//  vec2 uv\t\t   - actual fragment coord\n//  float sigma  >  0 - sigma Standard Deviation\n//  float kSigma >= 0 - sigma coefficient \n//\t  kSigma * sigma  -->  radius of the circular kernel\n//  float threshold   - edge sharpening threshold \nvec4 $(name)_smartDeNoise(vec2 uv, float sigma, float kSigma, float threshold)\n{\n\tfloat INV_SQRT_OF_2PI = 0.39894228040143267793994605993439; // 1.0/SQRT_OF_2PI\n\tfloat INV_PI = 0.31830988618379067153776752674503;\n\tfloat radius = round(kSigma*sigma);\n\tfloat radQ = radius * radius;\n\n\tfloat invSigmaQx2 = .5 / (sigma * sigma);\t  // 1.0 / (sigma^2 * 2.0)\n\tfloat invSigmaQx2PI = INV_PI * invSigmaQx2;\t// 1/(2 * PI * sigma^2)\n\n\tfloat invThresholdSqx2 = .5 / (threshold * threshold);\t // 1.0 / (sigma^2 * 2.0)\n\tfloat invThresholdSqrt2PI = INV_SQRT_OF_2PI / threshold;   // 1.0 / (sqrt(2*PI) * sigma^2)\n\n\tvec4 centrPx = $in(uv); \n\n\tfloat zBuff = 0.0;\n\tvec4 aBuff = vec4(0.0);\n\tvec2 size = vec2($size, $size);\n\n\tvec2 d;\n\tfor (d.x=-radius; d.x <= radius; d.x++) {\n\t\tfloat pt = sqrt(radQ-d.x*d.x);\t   // pt = yRadius: have circular trend\n\t\tfor (d.y=-pt; d.y <= pt; d.y++) {\n\t\t\tfloat blurFactor = exp( -dot(d , d) * invSigmaQx2 ) * invSigmaQx2PI;\n\n\t\t\tvec4 walkPx =  $in(uv+d/size);\n\t\t\tvec4 dC = walkPx-centrPx;\n\t\t\tfloat deltaFactor = exp( -dot(dC, dC) * invThresholdSqx2) * invThresholdSqrt2PI * blurFactor;\n\n\t\t\tzBuff += deltaFactor;\n\t\t\taBuff += deltaFactor*walkPx;\n\t\t}\n\t}\n\treturn aBuff/zBuff;\n}",
						"longdesc": "Fast  spatial deNoise filter, with circular gaussian kernel.",
						"name": "Denoiser",
						"outputs": [
							{
								"longdesc": "A color pattern that assigns a random color to each cell",
								"rgba": "$(name)_smartDeNoise($uv, $sigma, $ksigma, $threshold)",
								"shortdesc": "Random color",
								"type": "rgba"
							}
						],
						"parameters": [
							{
								"default": 10.0,
								"first": 0.0,
								"label": "Size",
								"last": 12.0,
								"longdesc": "The resolution of the denoiser",
								"name": "size",
								"type": "size"
							},
							{
								"control": "None",
								"default": 0.5,
								"label": "Sigma",
								"longdesc": "Standard Deviation sigma radius",
								"max": 1.0,
								"min": 0.005,
								"name": "sigma",
								"shortdesc": "Sigma",
								"step": 0.1,
								"type": "float"
							},
							{
								"control": "None",
								"default": 0.5,
								"label": "kSigma",
								"longdesc": "K factor sigma coefficient.\nkSigma = 1*sigma cover 68% of data\nkSigma = 2*sigma cover 95% of data - but there are over 3 times  more points to compute\nkSigma = 3*sigma cover 99.7% of data - but needs more than double the calculations of 2*sigma",
								"max": 1.0,
								"min": 0.0,
								"name": "ksigma",
								"shortdesc": "kSigma",
								"step": 0.1,
								"type": "float"
							},
							{
								"control": "None",
								"default": 0.5,
								"label": "Sharpening",
								"longdesc": "Edge sharpening threshold",
								"max": 1.0,
								"min": 0.0,
								"name": "threshold",
								"shortdesc": "Sharpening",
								"step": 0.1,
								"type": "float"
							}
						],
						"shortdesc": "Denoiser"
					},
					"type": "shader"
				},
				{
					"name": "18118_3",
					"node_position": {
						"x": -700.0,
						"y": 120.0
					},
					"parameters": {
						"h_angle": 30.0,
						"height_mult": 0.53,
						"r_angle": 300.0,
						"sha_prec": 64.0,
						"sha_soft": 0.41,
						"sha_soft_q": 23.0
					},
					"seed_int": 1345341312,
					"shader_model": {
						"code": "vec4 $(name_uv)_light = $(name)_light_2d($uv, $r_angle * 0.01745329251, $h_angle * 0.01745329251, $sha_soft, int($sha_prec), int($sha_soft_q), $height_mult, $seed);",
						"global": "vec2 rotate_v2(vec2 v, float a) {\n\tfloat s = sin(a);\n\tfloat c = cos(a);\n\tmat2 m = mat2(vec2(c, -s), vec2(s, c));\n\treturn m * v;\n}\n\nvec3 rodrigues_rotate(vec3 v, vec3 n, float a) {\n\treturn v * cos(a) + cross(n, v) * sin(a) + n * dot(n, v) * (1.0 - cos(a));\n}",
						"inputs": [
							{
								"default": "vec3(0.5, 0.5, 0.0)",
								"function": true,
								"label": "",
								"name": "nor",
								"type": "rgb"
							},
							{
								"default": "0.0",
								"function": true,
								"label": "",
								"name": "height",
								"type": "f"
							},
							{
								"default": "1.0",
								"function": true,
								"label": "",
								"name": "rough",
								"type": "f"
							}
						],
						"instance": "vec4 $(name)_light_2d(vec2 uv, float l_angle, float l_height, float shadow_softness, int shadow_precission, int shadow_iterations, float height_mult, float seed) {\n\tvec3 normals = $nor(uv);\n\tnormals = (normals - 0.5) * 2.0;\n\tvec3 light_dir = vec3(1.0, 0.0, 0.0);\n\tlight_dir = rodrigues_rotate(light_dir, vec3(0.0, 1.0, 0.0), l_height);\n\tlight_dir = rodrigues_rotate(light_dir, vec3(0.0, 0.0, 1.0), l_angle);\n\t\n\tfloat flatlambert = max(dot(light_dir, (vec3(0.5, 0.5, 0.0) - 0.5) * 2.0), 0.0);\n\t\n\tfloat lambert = max(dot(light_dir, normals), 0.0);\n\n\tfloat roughness = $rough(uv);\n\n\t// This is not correct roughmess, just something I put together, should be improved\n\tvec3 half_vector = normalize(light_dir + vec3(0.0, 0.0, -1.0));\n\tfloat specular = max(pow(dot(normals, light_dir ), 2.0 / roughness) * (1.0 - roughness), 0.0);\n\t//float specular = max(0.0, pow(dot(half_vector, normals), (1.0 - roughness) * 600.0)) * (1.0 - roughness);\n\n\t// Search length is the maximum length a 1 heigh shadow can reach at the light angle\n\tfloat search_length = min( 1.0 / tan(l_height), sqrt(2.0)); // search length should never be longer than the diagonal which i sqrt(2.0)\n\t//float height_mult = 0.1;\n\tsearch_length *= height_mult;\n\tfloat height = $height(uv) * height_mult;\n\tvec2 shadow_search_direction = normalize(-light_dir.xy);\n\tfloat shadow = 0.0;\n\t\n\tshadow_iterations = shadow_softness < 0.01 ? 1 : shadow_iterations;\n\t\n\tbool hit = false;\n\tfloat pass1_distance = 0.0;\n\t\n\tfor (int j = 0; j < shadow_iterations; j++) {\n\t\tvec2 rand2 = (rand2(rand2( uv + vec2(seed, float(j)))) - vec2(0.5, 1.0));\n\t\tvec2 random_search_direction = shadow_softness < 0.01 ? shadow_search_direction : rotate_v2(shadow_search_direction, rand2.x * shadow_softness);\n\t\tfor (int i = 0; i < shadow_precission; i++) {\n\t\t\tfloat dist = (float(i) / float(shadow_precission)) * search_length;\n\t\t\tvec2 sample_point = uv + random_search_direction * dist;\n\t\t\tfloat shadow_casting_height = height + tan(l_height) * dist;\n\t\t\tfloat sample_height = $height(sample_point) * height_mult + rand2.y * shadow_softness * 0.4;\n\t\t\tif (sample_height > shadow_casting_height) {\n\t\t\t\tshadow += 1.0 / float(shadow_iterations);\n\t\t\t\tbreak;\n\t\t\t}\n\t\t}\n\t}\n\t\n\treturn vec4(lambert, specular, 1.0 - shadow, flatlambert);\n}",
						"name": "Light2D Sun",
						"outputs": [
