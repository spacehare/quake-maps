					"parameters": {
						"size": 8.0
					},
					"seed_int": 0,
					"shader_model": {
						"code": "",
						"global": "",
						"inputs": [],
						"instance": "// https://www.shadertoy.com/view/XtV3RG\nfloat $(name)_f(vec2 uv) \n{\n\tint level = int(log2($size));\n\tivec2 position = ivec2(floor(uv * $size));\n\tint sum = 0;\n\t\n\tfor(int i = 0; i < level; i++)\n\t{\n\t\tivec2 a = (position >> ivec2(level - 1 - i) & ivec2(1));\n\t\tsum += ((4 - a.x - (a.y << 1)) % 4) << (2 * i);\n\t}\n\t\n\treturn float(sum) / float(2 << (level * 2 - 1));\n}",
						"name": "Bayer Pattern",
						"outputs": [
							{
								"f": "$(name)_f($(uv))",
								"shortdesc": "Output",
								"type": "f"
							}
						],
						"parameters": [
							{
								"default": 4.0,
								"first": 1.0,
								"label": "Grid Size",
								"last": 13.0,
								"name": "size",
