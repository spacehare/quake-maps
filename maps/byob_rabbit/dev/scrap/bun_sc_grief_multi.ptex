				{
					"name": "pixelize",
					"node_position": {
						"x": -3060.0,
						"y": 1100.0
					},
					"parameters": {
						"c": 255.0,
						"d": 256.0,
						"t": 0.0,
						"x": 8.0
					},
					"seed_int": 0,
					"shader_model": {
						"code": "vec2 $(name_uv)_uv = floor($uv*$x)+vec2(0.5);\nvec3 $(name_uv)_dither = $t;\n",
						"global": "float bayer_matrix(vec2 uv, int rounds) {\n\tivec2 iuv = ivec2(uv);\n\tint b[4] = int[4]( 0, 2, 3, 1 );\n\tfloat divisor = 1.0;\n\tint rv = 0;\n\tfor (int i = 0; i < rounds; ++i) {\n\t\trv *= 4;\n\t\tdivisor *= 4.0;\n\t\trv += b[(iuv.x%2)+2*(iuv.y%2)];\n\t\tiuv >>= 1;\n\t}\n\treturn float(rv)/divisor;\n}",
						"inputs": [
							{
								"default": "vec3(1.0)",
								"label": "",
								"longdesc": "The image to be pixelated",
								"name": "i",
								"shortdesc": "Input",
								"type": "rgb"
							}
						],
						"instance": "",
						"longdesc": "Creates a pixelated image from its input, and also quantifies the colors with optional dithering.",
						"name": "Pixelize",
						"outputs": [
							{
								"longdesc": "A pixelated version of the input image",
								"rgb": "floor($i($(name_uv)_uv/$x)*$c+$d*($(name_uv)_dither))/$c",
								"shortdesc": "Output",
								"type": "rgb"
							}
						],
						"parameters": [
							{
								"default": 7.0,
								"first": 4.0,
								"label": "Size",
								"last": 11.0,
								"longdesc": "Number of pixel columns of the output",
								"name": "x",
								"shortdesc": "Columns",
								"type": "size"
							},
							{
								"control": "None",
								"default": 4.0,
								"label": "Levels",
								"longdesc": "Number of color levels for each channel",
								"max": 32.0,
								"min": 2.0,
								"name": "c",
								"shortdesc": "Levels",
								"step": 1.0,
								"type": "float"
							},
							{
								"control": "None",
								"default": 0.5,
								"label": "Dither",
								"longdesc": "Amount of dithering in the output image",
								"max": 1.0,
								"min": 0.0,
								"name": "d",
								"shortdesc": "Dithering",
								"step": 0.01,
								"type": "float"
							},
							{
								"default": 0.0,
								"label": "Dither type",
								"name": "t",
								"type": "enum",
								"values": [
									{
										"name": "Random",
										"value": "fract(vec3(dot(vec2(171.0, 231.0), $(name_uv)_uv))/vec3(103.0, 71.0, 97.0))"
									},
									{
										"name": "Bayer 2x2",
										"value": "vec3(bayer_matrix($(name_uv)_uv, 1))"
									},
									{
										"name": "Bayer 4x4",
										"value": "vec3(bayer_matrix($(name_uv)_uv, 2))"
									},
									{
										"name": "Bayer 8x8",
										"value": "vec3(bayer_matrix($(name_uv)_uv, 3))"
									},
									{
										"name": "Bayer 16x16",
										"value": "vec3(bayer_matrix($(name_uv)_uv, 4))"
									}
								]
							}
						]
					},
					"type": "shader"
				},
				{
					"generic_size": 1,
					"name": "blend2_5",
					"node_position": {
						"x": -3060.0,
						"y": 1260.0
					},
					"parameters": {
						"amount1": 0.5,
						"blend_type1": 0.0
